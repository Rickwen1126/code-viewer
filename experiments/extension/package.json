{
  "name": "code-viewer-bridge",
  "displayName": "Code Viewer Bridge",
  "description": "Experiment: VSCode Extension API capabilities for Code Viewer",
  "version": "0.0.5",
  "engines": {
    "vscode": "^1.93.0"
  },
  "extensionDependencies": [
    "vscode.git"
  ],
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeViewerBridge.runAllExperiments",
        "title": "Code Viewer: Run All Experiments"
      },
      {
        "command": "codeViewerBridge.experimentWs",
        "title": "Code Viewer: Experiment - WebSocket"
      },
      {
        "command": "codeViewerBridge.experimentLsp",
        "title": "Code Viewer: Experiment - LSP Proxy"
      },
      {
        "command": "codeViewerBridge.experimentWorkspace",
        "title": "Code Viewer: Experiment - Workspace Management"
      },
      {
        "command": "codeViewerBridge.experimentFs",
        "title": "Code Viewer: Experiment - File System"
      },
      {
        "command": "codeViewerBridge.experimentGit",
        "title": "Code Viewer: Experiment - Git API"
      },
      {
        "command": "codeViewerBridge.experimentDiagnostics",
        "title": "Code Viewer: Experiment - Diagnostics"
      },
      {
        "command": "codeViewerBridge.experimentCopilot",
        "title": "Code Viewer: Experiment - Copilot Detection"
      },
      {
        "command": "codeViewerBridge.experimentLm",
        "title": "Code Viewer: Experiment - Language Model API"
      },
      {
        "command": "codeViewerBridge.runDesktopExperiments",
        "title": "Code Viewer: Run Desktop Experiments (Phase B)"
      },
      {
        "command": "codeViewerBridge.desktopB1",
        "title": "Code Viewer: Desktop B1 - Model Enumeration"
      },
      {
        "command": "codeViewerBridge.desktopB2",
        "title": "Code Viewer: Desktop B2 - LM Send Request"
      },
      {
        "command": "codeViewerBridge.desktopB3",
        "title": "Code Viewer: Desktop B3 - Chat Panel Integration"
      },
      {
        "command": "codeViewerBridge.desktopB4",
        "title": "Code Viewer: Desktop B4 - Response Detection"
      },
      {
        "command": "codeViewerBridge.desktopB5",
        "title": "Code Viewer: Desktop B5 - Chat Session Reading"
      },
      {
        "command": "codeViewerBridge.desktopB6",
        "title": "Code Viewer: Desktop B6 - WebSocket Backend"
      },
      {
        "command": "codeViewerBridge.desktopB7",
        "title": "Code Viewer: Desktop B7 - LSP Desktop"
      },
      {
        "command": "codeViewerBridge.desktopB9",
        "title": "Code Viewer: Desktop B9 - Agent Interaction"
      },
      {
        "command": "codeViewerBridge.desktopB8",
        "title": "Code Viewer: Desktop B8 - Session Takeover"
      },
      {
        "command": "codeViewerBridge.runPhaseC",
        "title": "Code Viewer: Run Phase C (End-to-End)"
      },
      {
        "command": "codeViewerBridge.desktopC1",
        "title": "Code Viewer: Desktop C1 - Desktop→Mobile"
      },
      {
        "command": "codeViewerBridge.desktopC2",
        "title": "Code Viewer: Desktop C2 - Mobile→Desktop"
      },
      {
        "command": "codeViewerBridge.desktopC3",
        "title": "Code Viewer: Desktop C3 - Session Continuity"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild",
    "compile": "tsc -p ./",
    "esbuild": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.93.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0"
  },
  "dependencies": {
    "ws": "^8.16.0"
  }
}
