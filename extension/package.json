{
  "name": "code-viewer-extension",
  "displayName": "Code Viewer",
  "description": "Mobile Code Viewer VS Code Extension",
  "version": "0.0.5",
  "private": true,
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeViewer.connect",
        "title": "Code Viewer: Connect to Backend"
      },
      {
        "command": "codeViewer.disconnect",
        "title": "Code Viewer: Disconnect from Backend"
      }
    ],
    "configuration": {
      "title": "Code Viewer",
      "properties": {
        "codeViewer.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Code Viewer connection to backend. Set to true in workspace settings to activate."
        },
        "codeViewer.backendUrl": {
          "type": "string",
          "default": "ws://localhost:4800",
          "description": "Backend WebSocket URL"
        },
        "codeViewer.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose Code Viewer debug logging"
        }
      }
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc --emitDeclarationOnly && esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "mkdir -p dist && esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "typecheck": "tsc --noEmit",
    "package": "pnpm run build && vsce package --no-dependencies"
  },
  "dependencies": {
    "@code-viewer/shared": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.100.0",
    "@types/ws": "^8.18.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
